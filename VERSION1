<!-- 底部信息 -->
<footer style="text-align:center;padding:20px;color:var(--text-secondary);font-size:0.75rem;">
    <p>适用对象：英语 B1 水平，目标 B2 / KBCC ENG 1200，在布鲁克林学习</p>
    <p style="margin-top:4px;">计划制定：2026 年 5 月 · 周期：5–6 个月 · 每天 25–35 分钟</p>
    <div class="btn-group mt-12" style="justify-content:center;">
        <button class="btn btn-xs btn-ghost" onclick="clearAllData()">⚠️ 清除所有数据</button>
        <button class="btn btn-xs btn-ghost" onclick="resetStreak()">🔄 重置 Streak</button>
    </div>
</footer>

<!-- 浮动启动按钮 -->
<button class="float-btn" onclick="scrollToTasks()" title="今日启动">⚡</button>

<!-- 庆祝覆盖层 -->
<div class="celebrate-overlay" id="celebrateOverlay" style="display:none;"></div>

<script>
    (function() {
        // ============ CONSTANTS ============
        const STORAGE_KEY = 'engB1B2_learningPanel';
        const todayStr = getDateStr(new Date());
        const dayOfWeek = new Date().getDay(); // 0=Sun, 1=Mon, ... 6=Sat

        // ============ DOM REFS ============
        const $checklist = document.getElementById('checklist');
        const $progressBar = document.getElementById('progressBar');
        const $progressPct = document.getElementById('progressPct');
        const $streakNum = document.getElementById('streakNum');
        const $streakBadge = document.getElementById('streakBadge');
        const $statusDot = document.getElementById('statusDot');
        const $statusLabel = document.getElementById('statusLabel');
        const $completionSummary = document.getElementById('completionSummary');
        const $heroDayType = document.getElementById('heroDayType');
        const $heroDate = document.getElementById('heroDate');
        const $taskHeading = document.getElementById('taskHeading');
        const $toast = document.getElementById('toast');
        const $celebrateOverlay = document.getElementById('celebrateOverlay');
        const $copyPromptBtn = document.getElementById('copyPromptBtn');
        const $reward30Days = document.getElementById('reward30Days');
        const $reward60Days = document.getElementById('reward60Days');
        const $reward30Bar = document.getElementById('reward30Bar');
        const $reward60Bar = document.getElementById('reward60Bar');
        const $reward30Desc = document.getElementById('reward30Desc');
        const $reward60Desc = document.getElementById('reward60Desc');
        const $progressWrap = document.getElementById('progressWrap');

        // ============ DATA MODEL ============
        function getDefaultData() {
            return {
                startDate: '2026-05-14',
                completedDates: [], // array of date strings
                taskChecks: {}, // {dateStr: {taskId: true}}
                threeThings: {}, // {thing1: true/false, thing2: ..., thing3: ...}
                errors: { err1: '', err2: '', err3: '' },
                commitTime: '',
                commitPlace: '',
                reward30: '',
                reward60: '',
                lastStreakCheck: '',
            };
        }

        function loadData() {
            try {
                const raw = localStorage.getItem(STORAGE_KEY);
                if (raw) {
                    const parsed = JSON.parse(raw);
                    // Merge with defaults
                    const defaults = getDefaultData();
                    for (const key in defaults) {
                        if (!(key in parsed)) parsed[key] = defaults[key];
                    }
                    return parsed;
                }
            } catch (e) { /* fall through */ }
            return getDefaultData();
        }

        function saveData(data) {
            try {
                localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
            } catch (e) {
                showToast('⚠️ 存储空间不足，请清理数据');
            }
        }

        let appData = loadData();

        // ============ HELPERS ============
        function getDateStr(date) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function getYesterdayStr() {
            const d = new Date();
            d.setDate(d.getDate() - 1);
            return getDateStr(d);
        }

        function calcStreak(completedDates) {
            if (!completedDates || completedDates.length === 0) return 0;
            const sorted = [...new Set(completedDates)].sort().reverse();
            const today = getDateStr(new Date());
            const yesterday = getYesterdayStr();
            // Check if today or yesterday is in the set to start counting
            let startRef = null;
            if (sorted[0] === today) startRef = today;
            else if (sorted[0] === yesterday) startRef = yesterday;
            else {
                // Check if today is not yet done, but yesterday was done
                if (sorted.includes(yesterday)) startRef = yesterday;
                else return 0; // neither today nor yesterday done
            }
            if (!startRef) return 0;
            let streak = 0;
            const checkDate = new Date(startRef);
            for (const s of sorted) {
                const expected = getDateStr(checkDate);
                if (s === expected) {
                    streak++;
                    checkDate.setDate(checkDate.getDate() - 1);
                } else if (s < expected) {
                    break;
                }
            }
            return streak;
        }

        function isTodayCompleted() {
            return appData.completedDates.includes(todayStr);
        }

        function getTodayTaskChecks() {
            return appData.taskChecks[todayStr] || {};
        }

        function setTodayTaskCheck(taskId, checked) {
            if (!appData.taskChecks[todayStr]) appData.taskChecks[todayStr] = {};
            if (checked) {
                appData.taskChecks[todayStr][taskId] = true;
            } else {
                delete appData.taskChecks[todayStr][taskId];
            }
            // Clean up empty
            if (Object.keys(appData.taskChecks[todayStr]).length === 0) {
                delete appData.taskChecks[todayStr];
            }
            saveData(appData);
            updateAllUI();
        }

        function getTodayTaskCount() {
            return document.querySelectorAll('#checklist li[data-task-id]').length;
        }

        function getTodayCheckedCount() {
            const checks = getTodayTaskChecks();
            let count = 0;
            document.querySelectorAll('#checklist li[data-task-id]').forEach(li => {
                if (checks[li.dataset.taskId]) count++;
            });
            return count;
        }

        // ============ DAY TYPE DETECTION ============
        function getDayTypeInfo() {
            const map = {
                0: { type: '复盘 + 备料日', emoji: '📋', heading: '周日复盘 & 备料流程', color: 'var(--green-bright)' },
                1: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程', color: 'var(--accent)' },
                2: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程', color: 'var(--accent)' },
                3: { type: '语法专项日', emoji: '🔬', heading: '周三语法专项流程', color: 'var(--orange)' },
                4: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程', color: 'var(--accent)' },
                5: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程', color: 'var(--accent)' },
                6: { type: '写作日', emoji: '✍️', heading: '周六写作日流程', color: 'var(--blue)' },
            };
            return map[dayOfWeek] || map[1];
        }

        function getTasksForDay() {
            const dayMap = {
                0: [
                    { id: 'sun1', text: '本周错误总结——翻 Obsidian 错误记录，回答三个问题', time: '10分钟',
                        badge: 'core' },
                    { id: 'sun2', text: '准备下周材料——找 5 篇 VOA 故事，AI 翻中文存 Obsidian', time: '10分钟',
                    badge: 'core' },
                    { id: 'sun3', text: '最低底线：至少准备好下周 3 篇材料', time: '5分钟', badge: 'minimum' },
                ],
                3: [
                    { id: 'wed1', text: '找出本周最高频错误——翻 Obsidian 数哪类错误最多', time: '5分钟', badge: 'core' },
                    { id: 'wed2', text: '读对应 Grammar in Use Unit——只读不做题', time: '10分钟', badge: 'core' },
                    { id: 'wed3', text: '造 8 个句子——用该语法点，发 AI 校对', time: '10分钟', badge: 'core' },
                    { id: 'wed4', text: '最低底线：至少读 1 个 Unit 并造 3 个句子', time: '5分钟', badge: 'minimum' },
                ],
                6: [
                    { id: 'sat1', text: '写 150–200 字短文——含定语从句和状语从句', time: '20分钟', badge: 'core' },
                    { id: 'sat2', text: '自查 + AI 校对——先自查再发 AI', time: '10分钟', badge: 'core' },
                    { id: 'sat3', text: '最低底线：写 80 字短文并发 AI 校对', time: '10分钟', badge: 'minimum' },
                ],
            };
            // Default: translation day (Mon, Tue, Thu, Fri)
            const defaultTasks = [
                { id: 't1', text: '昨日错误回顾——打开 Obsidian 看昨天 2–3 个错误句子', time: '5分钟', badge: 'core' },
                { id: 't2', text: '裸翻训练（核心）——看中文版，不看英文原文直接打出英文', time: '10分钟', badge: 'core' },
                { id: 't3', text: '自查——检查动词形式、过去完成时、从句引导词', time: '5分钟', badge: 'core' },
                { id: 't4', text: 'AI 对比 + 记录错误——发 ChatGPT，对比修改版和原文', time: '5分钟', badge: 'core' },
                { id: 't5', text: '最低底线：翻译 5 句话，5 分钟内结束（不可破）', time: '5分钟', badge: 'minimum' },
            ];
            return dayMap[dayOfWeek] || defaultTasks;
        }

        // ============ RENDER CHECKLIST ============
        function renderChecklist() {
            const tasks = getTasksForDay();
            const checks = getTodayTaskChecks();
            $checklist.innerHTML = '';
            tasks.forEach(task => {
                const li = document.createElement('li');
                li.dataset.taskId = task.id;
                if (checks[task.id]) li.classList.add('checked');
                li.innerHTML = `
                    <span class="cl-checkbox"></span>
                    <span class="cl-text">${task.text}</span>
                    <span class="cl-badge ${task.badge}">${task.time}</span>
                `;
                li.addEventListener('click', () => {
                    const currentlyChecked = li.classList.contains('checked');
                    if (currentlyChecked) {
                        li.classList.remove('checked');
                        setTodayTaskCheck(task.id, false);
                    } else {
                        li.classList.add('checked');
                        setTodayTaskCheck(task.id, true);
                        // Check if all done
                        if (getTodayCheckedCount() >= getTodayTaskCount() && getTodayTaskCount() >
                            0) {
                            markDayCompleted();
                        }
                    }
                });
                $checklist.appendChild(li);
            });
            updateCompletionSummary();
        }

        function updateCompletionSummary() {
            const total = getTodayTaskCount();
            const checked = getTodayCheckedCount();
            $completionSummary.textContent = `完成 ${checked} / ${total} 项`;
            const pct = total > 0 ? Math.round((checked / total) * 100) : 0;
            $progressPct.textContent = pct + '%';
            $progressBar.style.width = pct + '%';
            // Update status
            if (pct === 0 && !isTodayCompleted()) {
                setStatus('idle', '未开始');
            } else if (pct >= 100 || isTodayCompleted()) {
                setStatus('done', '已完成');
            } else {
                setStatus('active', '进行中');
            }
        }

        function setStatus(state, label) {
            $statusDot.className = 'status-dot ' + state;
            $statusLabel.textContent = label;
        }

        function markDayCompleted() {
            if (!appData.completedDates.includes(todayStr)) {
                appData.completedDates.push(todayStr);
                appData.completedDates.sort();
                saveData(appData);
                showCelebration();
                showToast('🎉 太棒了！今日任务全部完成！');
            }
            updateAllUI();
        }

        function showCelebration() {
            const overlay = $celebrateOverlay;
            overlay.style.display = 'flex';
            overlay.innerHTML =
                '<span class="celebrate-text">🔥 今日完成！<br><small style="font-size:0.6em;">坚持就是胜利</small></span>';
            setTimeout(() => {
                overlay.style.display = 'none';
                overlay.innerHTML = '';
            }, 1800);
        }

        // ============ UPDATE ALL UI ============
        function updateAllUI() {
            const streak = calcStreak(appData.completedDates);
            $streakNum.textContent = streak;
            if (streak === 0 && appData.completedDates.length === 0) {
                $streakBadge.classList.remove('broken');
            } else if (streak === 0 && appData.completedDates.length > 0) {
                $streakBadge.classList.add('broken');
                $streakNum.textContent = '0';
            } else {
                $streakBadge.classList.remove('broken');
            }
            updateCompletionSummary();
            updateRewards();
            updateHeroDate();
            updateThreeThingsUI();
            updateEditableFields();
            updateErrorFields();
        }

        function updateHeroDate() {
            const dayInfo = getDayTypeInfo();
            const now = new Date();
            const dateStr = now.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric',
                weekday: 'long' });
            $heroDate.textContent = dateStr;
            $heroDayType.textContent = dayInfo.emoji + ' ' + dayInfo.type;
            $heroDayType.style.color = dayInfo.color;
            $heroDayType.style.background = dayInfo.color.replace(')', '22').replace('rgb',
                'rgba').replace('var(', '').replace(')', '22');
            if (dayInfo.color.startsWith('var')) {
                const varName = dayInfo.color.match(/var\(([^)]+)\)/)[1];
                const resolved = getComputedStyle(document.documentElement).getPropertyValue(varName).trim();
                $heroDayType.style.color = resolved;
                $heroDayType.style.background = resolved + '22';
            }
            $taskHeading.textContent = dayInfo.heading;
        }

        function updateRewards() {
            const completedCount = appData.completedDates.length;
            const reward30Text = appData.reward30 || '设置你的奖励';
            const reward60Text = appData.reward60 || '设置你的奖励';
            $reward30Days.textContent = Math.min(completedCount, 30) + '/30';
            $reward60Days.textContent = Math.min(completedCount, 60) + '/60';
            $reward30Bar.style.width = Math.min(100, Math.round((completedCount / 30) * 100)) + '%';
            $reward60Bar.style.width = Math.min(100, Math.round((completedCount / 60) * 100)) + '%';
            $reward30Desc.textContent = reward30Text;
            $reward60Desc.textContent = reward60Text;
            if (completedCount >= 30) {
                $reward30Days.style.color = 'var(--green-bright)';
                $reward30Bar.style.background = 'var(--green-bright)';
            }
            if (completedCount >= 60) {
                $reward60Days.style.color = 'var(--green-bright)';
                $reward60Bar.style.background = 'var(--green-bright)';
            }
        }

        function updateThreeThingsUI() {
            document.querySelectorAll('#threeThingsList li').forEach(li => {
                const id = li.dataset.id;
                if (appData.threeThings[id]) {
                    li.classList.add('checked');
                } else {
                    li.classList.remove('checked');
                }
            });
        }

        function updateEditableFields() {
            const fields = ['commitTime', 'commitPlace', 'reward30', 'reward60'];
            fields.forEach(key => {
                const el = document.getElementById(key);
                if (el && appData[key] !== undefined && appData[key] !== '') {
                    el.textContent = appData[key];
                }
            });
        }

        function updateErrorFields() {
            ['err1', 'err2', 'err3'].forEach(key => {
                const el = document.querySelector(`[data-key="${key}"]`);
                if (el && appData.errors[key]) {
                    el.textContent = appData.errors[key];
                }
            });
        }

        // ============ ACTIONS ============
        function scrollToTasks() {
            const el = document.getElementById('taskCard');
            if (el) {
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                // Brief highlight
                el.style.boxShadow = '0 0 0 4px var(--accent-glow)';
                setTimeout(() => { el.style.boxShadow = ''; }, 1200);
            }
        }

        function scrollToMinimal() {
            const el = document.getElementById('minimumSection');
            if (el) {
                el.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }

        function markAllDone() {
            const tasks = getTasksForDay();
            tasks.forEach(task => {
                if (!appData.taskChecks[todayStr]) appData.taskChecks[todayStr] = {};
                appData.taskChecks[todayStr][task.id] = true;
            });
            if (!appData.completedDates.includes(todayStr)) {
                appData.completedDates.push(todayStr);
                appData.completedDates.sort();
            }
            saveData(appData);
            renderChecklist();
            updateAllUI();
            showCelebration();
            showToast('✅ 今日已全部标记完成！');
        }

        function resetToday() {
            if (appData.taskChecks[todayStr]) {
                delete appData.taskChecks[todayStr];
            }
            appData.completedDates = appData.completedDates.filter(d => d !== todayStr);
            saveData(appData);
            renderChecklist();
            updateAllUI();
            setStatus('idle', '未开始');
            showToast('🔄 今日进度已重置');
        }

        function toggleThing(li) {
            const id = li.dataset.id;
            appData.threeThings[id] = !appData.threeThings[id];
            saveData(appData);
            updateThreeThingsUI();
        }

        function copyPrompt() {
            const text = document.getElementById('promptCode').textContent.trim();
            navigator.clipboard.writeText(text).then(() => {
                $copyPromptBtn.textContent = '✓ 已复制';
                $copyPromptBtn.classList.add('copied');
                showToast('📋 提示词已复制到剪贴板');
                setTimeout(() => {
                    $copyPromptBtn.textContent = '📋 复制';
                    $copyPromptBtn.classList.remove('copied');
                }, 2000);
            }).catch(() => {
                showToast('⚠️ 复制失败，请手动选择复制');
            });
        }

        function clearErrors() {
            appData.errors = { err1: '', err2: '', err3: '' };
            saveData(appData);
            document.querySelectorAll('#errorTop3 .editable-inline').forEach(el => {
                el.textContent = el.dataset.key === 'err1' ? '点击填写最高频错误' :
                    el.dataset.key === 'err2' ? '点击填写第二高频错误' : '点击填写第三高频错误';
            });
            showToast('🗑️ 本周错误记录已清空');
        }

        function clearAllData() {
            if (confirm('确定要清除所有数据吗？包括 streak、任务记录、错误记录等。此操作不可撤销。')) {
                localStorage.removeItem(STORAGE_KEY);
                appData = getDefaultData();
                renderChecklist();
                updateAllUI();
                setStatus('idle', '未开始');
                document.querySelectorAll('.editable-inline').forEach(el => {
                    el.textContent = el.dataset.key === 'commitTime' ? '___:___' :
                        el.dataset.key === 'commitPlace' ? '____________' :
                        el.dataset.key === 'reward30' ? '________________________' :
                        el.dataset.key === 'reward60' ? '________________________' :
                        el.dataset.key === 'err1' ? '点击填写最高频错误' :
                        el.dataset.key === 'err2' ? '点击填写第二高频错误' : '点击填写第三高频错误';
                });
                showToast('⚠️ 所有数据已清除');
            }
        }

        function resetStreak() {
            if (confirm('确定要重置连续打卡记录吗？这将清除所有完成日期。')) {
                appData.completedDates = [];
                appData.taskChecks = {};
                saveData(appData);
                renderChecklist();
                updateAllUI();
                setStatus('idle', '未开始');
                showToast('🔄 Streak 已重置');
            }
        }

        function showToast(msg) {
            $toast.textContent = msg;
            $toast.classList.add('show');
            clearTimeout($toast._timeout);
            $toast._timeout = setTimeout(() => {
                $toast.classList.remove('show');
            }, 2200);
        }

        function toggleCollapsible(el) {
            el.classList.toggle('open');
        }

        // ============ EDITABLE FIELDS SAVE ============
        function setupEditableListeners() {
            document.querySelectorAll('.editable-inline[data-key]').forEach(el => {
                el.addEventListener('blur', () => {
                    const key = el.dataset.key;
                    const text = el.textContent.trim();
                    if (['err1', 'err2', 'err3'].includes(key)) {
                        appData.errors[key] = text;
                    } else {
                        appData[key] = text;
                    }
                    saveData(appData);
                    if (key === 'reward30' || key === 'reward60') updateRewards();
                });
                el.addEventListener('keydown', (e) => {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        el.blur();
                    }
                });
            });
        }

        // ============ SCROLL LISTENER FOR PROGRESS WRAP ============
        function setupScrollListener() {
            window.addEventListener('scroll', () => {
                if (window.scrollY > 50) {
                    $progressWrap.classList.add('scrolled');
                } else {
                    $progressWrap.classList.remove('scrolled');
                }
            });
        }

        // ============ INIT ============
        function init() {
            renderChecklist();
            updateAllUI();
            setupEditableListeners();
            setupScrollListener();
            // Restore editable fields
            updateEditableFields();
            updateErrorFields();
            // Set hero info
            updateHeroDate();
            // Check if today already completed
            if (isTodayCompleted()) {
                setStatus('done', '已完成');
                // Ensure all tasks checked
                const tasks = getTasksForDay();
                if (!appData.taskChecks[todayStr]) appData.taskChecks[todayStr] = {};
                let allChecked = true;
                tasks.forEach(t => {
                    if (!appData.taskChecks[todayStr][t.id]) allChecked = false;
                });
                if (!allChecked) {
                    tasks.forEach(t => { appData.taskChecks[todayStr][t.id] = true; });
                    saveData(appData);
                    renderChecklist();
                }
                updateCompletionSummary();
            }
            console.log('📊 英语 B1→B2 训练面板已就绪 | 今日: ' + getDayTypeInfo().type + ' | Streak: ' + calcStreak(
                appData.completedDates) + ' 天');
        }

        // ============ GLOBAL EXPOSURES ============
        window.scrollToTasks = scrollToTasks;
        window.scrollToMinimal = scrollToMinimal;
        window.markAllDone = markAllDone;
        window.resetToday = resetToday;
        window.toggleThing = toggleThing;
        window.copyPrompt = copyPrompt;
        window.clearErrors = clearErrors;
        window.clearAllData = clearAllData;
        window.resetStreak = resetStreak;
        window.toggleCollapsible = toggleCollapsible;

        // ============ START ============
        init();
    })();
</script>
</body>
</html>