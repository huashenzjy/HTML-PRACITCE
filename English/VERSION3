<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>英语 B1 → B2 提升计划 | 每日训练面板</title>
    <style>
        :root {
            --bg: #F8F6FC;
            --bg-card: #FFFFFF;
            --bg-card-hover: #F5F3FA;
            --bg-elevated: #EDEAF5;
            --border: #E0DCF0;
            --border-light: #CEC8E5;
            --text: #2C2C3A;
            --text-secondary: #6E6E82;
            --text-heading: #1F1F2E;
            --text-bright: #0D0D1A;
            --accent: #6B5B95;
            --accent-soft: #6B5B9518;
            --accent-glow: #6B5B9530;
            --green: #4A9E7C;
            --green-soft: #4A9E7C1A;
            --green-bright: #3B8C6A;
            --red-soft: #E07B6C1A;
            --red: #E07B6C;
            --orange: #D4854A;
            --blue-soft: #5B8DB91A;
            --blue: #6B9EC4;
            --sync-blue: #5B9BD5;
            --radius-sm: 8px;
            --radius: 12px;
            --radius-lg: 16px;
            --radius-xl: 20px;
            --shadow-sm: 0 1px 3px rgba(107, 91, 149, 0.06);
            --shadow: 0 4px 20px rgba(107, 91, 149, 0.08);
            --shadow-lg: 0 8px 32px rgba(107, 91, 149, 0.12);
            --transition: 0.2s cubic-bezier(0.4, 0, 0.2, 1);
            --font-mono: 'SF Mono', 'Cascadia Code', 'Consolas', 'Monaco', monospace;
            --font-sans: system-ui, -apple-system, 'Segoe UI', 'Helvetica Neue', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }
        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--font-sans);
            line-height: 1.6;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            padding-bottom: 100px;
            background-image: radial-gradient(ellipse at 20% 10%, #EDEAF5 0%, transparent 60%), radial-gradient(ellipse at 80% 90%, #F5F3FA 0%, transparent 60%);
            background-attachment: fixed;
        }
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: var(--border);
            border-radius: 3px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--border-light);
        }

        /* TOP BAR */
        .top-bar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(248, 246, 252, 0.85);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 14px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }
        .top-bar-left {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
        }
        .logo-text {
            font-weight: 700;
            font-size: 1rem;
            color: var(--text-heading);
            letter-spacing: -0.01em;
            white-space: nowrap;
        }
        .logo-dot {
            display: inline-block;
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--accent);
            margin-right: 6px;
            vertical-align: middle;
        }
        .streak-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: var(--accent-soft);
            border: 1px solid var(--accent-glow);
            padding: 6px 14px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--accent);
            white-space: nowrap;
        }
        .streak-badge.broken {
            background: var(--red-soft);
            border-color: #E07B6C40;
            color: var(--red);
        }
        .streak-num {
            font-size: 1.3rem;
            font-weight: 800;
            font-family: var(--font-mono);
        }
        .status-indicator {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            font-size: 0.85rem;
            font-weight: 500;
            white-space: nowrap;
        }
        .status-dot {
            width: 9px;
            height: 9px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .status-dot.idle {
            background: #B0ADBD;
        }
        .status-dot.active {
            background: var(--accent);
            animation: pulse-dot 1.8s ease-in-out infinite;
        }
        .status-dot.done {
            background: var(--green-bright);
            box-shadow: 0 0 10px var(--green-soft);
        }
        @keyframes pulse-dot {
            0%,
            100% {
                box-shadow: 0 0 0 0 var(--accent-glow);
            }
            50% {
                box-shadow: 0 0 0 10px transparent;
            }
        }

        /* SYNC & USER */
        .sync-indicator {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            font-size: 0.78rem;
            font-weight: 500;
            color: var(--text-secondary);
            white-space: nowrap;
        }
        .sync-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
            transition: background 0.3s;
        }
        .sync-dot.synced {
            background: var(--green-bright);
        }
        .sync-dot.syncing {
            background: var(--sync-blue);
            animation: pulse-dot 1.2s ease-in-out infinite;
        }
        .sync-dot.error {
            background: var(--red);
        }
        .sync-dot.offline {
            background: #B0ADBD;
        }
        .user-info {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.85rem;
            font-weight: 500;
            color: var(--text-heading);
        }
        .user-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid var(--accent-soft);
        }
        .btn-login {
            background: #FFFFFF;
            border: 1px solid var(--border);
            color: var(--text-heading);
            padding: 8px 16px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
        }
        .btn-login:hover {
            background: var(--bg-elevated);
            border-color: var(--accent);
            color: var(--accent);
        }

        /* PROGRESS BAR */
        .progress-wrap {
            padding: 0 20px;
            position: sticky;
            top: 60px;
            z-index: 99;
            background: rgba(248, 246, 252, 0.8);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            padding-top: 10px;
            padding-bottom: 6px;
            border-bottom: 1px solid transparent;
            transition: border-color 0.3s;
        }
        .progress-wrap.scrolled {
            border-bottom: 1px solid var(--border);
        }
        .progress-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 5px;
            font-size: 0.8rem;
            color: var(--text-secondary);
        }
        .progress-pct {
            font-weight: 700;
            font-size: 0.95rem;
            color: var(--text-heading);
            font-family: var(--font-mono);
        }
        .progress-bar-outer {
            height: 5px;
            background: var(--border);
            border-radius: 10px;
            overflow: hidden;
        }
        .progress-bar-inner {
            height: 100%;
            background: linear-gradient(90deg, #6B5B95, #9B8EC4, #6B5B95);
            background-size: 200% 100%;
            border-radius: 10px;
            transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            animation: shimmer 3s ease-in-out infinite;
        }
        @keyframes shimmer {
            0%,
            100% {
                background-position: 0% 50%;
            }
            50% {
                background-position: 100% 50%;
            }
        }

        /* MAIN */
        .main-container {
            max-width: 900px;
            margin: 0 auto;
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* CARDS */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 22px 24px;
            transition: var(--transition);
            position: relative;
            box-shadow: var(--shadow-sm);
        }
        .card:hover {
            border-color: var(--border-light);
            box-shadow: var(--shadow);
        }
        .card.accent-left {
            border-left: 3px solid var(--accent);
        }
        .card.green-left {
            border-left: 3px solid var(--green);
        }
        .card.orange-left {
            border-left: 3px solid var(--orange);
        }
        .card-highlight {
            background: #FFFFFF;
            border-color: var(--accent-glow);
            box-shadow: 0 0 40px rgba(107, 91, 149, 0.06);
        }
        .card-title {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-secondary);
            font-weight: 600;
            margin-bottom: 10px;
        }
        .card-heading {
            font-size: 1.15rem;
            font-weight: 700;
            color: var(--text-heading);
            margin-bottom: 6px;
            letter-spacing: -0.01em;
        }
        .card-subtitle {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-bottom: 14px;
        }

        /* HERO */
        .hero-section {
            text-align: center;
            padding: 30px 20px 20px;
        }
        .hero-identity {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-heading);
            letter-spacing: -0.02em;
            margin-bottom: 6px;
            line-height: 1.3;
        }
        .hero-identity .em {
            color: var(--accent);
        }
        .hero-date-info {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-bottom: 4px;
        }
        .hero-day-type {
            display: inline-block;
            background: var(--accent-soft);
            color: var(--accent);
            padding: 5px 14px;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
            margin: 8px 0 14px;
            letter-spacing: 0.02em;
        }

        /* BUTTONS */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 11px 22px;
            border-radius: 25px;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            border: none;
            transition: all 0.25s;
            font-family: var(--font-sans);
            letter-spacing: 0.01em;
            white-space: nowrap;
            text-decoration: none;
        }
        .btn-primary {
            background: var(--accent);
            color: #FFFFFF;
            box-shadow: 0 4px 20px rgba(107, 91, 149, 0.3);
        }
        .btn-primary:hover {
            background: #7A6BA5;
            box-shadow: 0 6px 28px rgba(107, 91, 149, 0.4);
            transform: translateY(-1px);
        }
        .btn-outline {
            background: transparent;
            border: 1.5px solid var(--border-light);
            color: var(--text);
        }
        .btn-outline:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: rgba(107, 91, 149, 0.04);
        }
        .btn-sm {
            padding: 7px 14px;
            font-size: 0.8rem;
            border-radius: 18px;
        }
        .btn-xs {
            padding: 4px 10px;
            font-size: 0.72rem;
            border-radius: 14px;
            font-weight: 500;
        }
        .btn-ghost {
            background: transparent;
            border: 1px solid transparent;
            color: var(--text-secondary);
            padding: 6px 12px;
        }
        .btn-ghost:hover {
            color: var(--text);
            background: rgba(107, 91, 149, 0.04);
            border-color: var(--border);
            border-radius: 8px;
        }
        .btn-group {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            align-items: center;
        }

        /* CHECKLIST */
        .checklist {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 2px;
        }
        .checklist li {
            display: flex;
            align-items: flex-start;
            gap: 11px;
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: var(--transition);
            border: 1px solid transparent;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }
        .checklist li:hover {
            background: rgba(107, 91, 149, 0.04);
        }
        .checklist li.checked {
            opacity: 0.75;
        }
        .checklist li.checked .cl-text {
            text-decoration: line-through;
            text-decoration-color: var(--text-secondary);
            text-decoration-thickness: 1px;
        }
        .cl-checkbox {
            width: 20px;
            height: 20px;
            border-radius: 6px;
            border: 2px solid var(--border-light);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.2s;
            margin-top: 1px;
            position: relative;
            background: #FFFFFF;
        }
        .checklist li.checked .cl-checkbox {
            background: var(--green);
            border-color: var(--green);
        }
        .cl-checkbox::after {
            content: '';
            position: absolute;
            width: 5px;
            height: 9px;
            border: solid #fff;
            border-width: 0 2px 2px 0;
            transform: rotate(45deg) scale(0);
            transition: transform 0.2s;
            top: 3px;
            left: 6px;
        }
        .checklist li.checked .cl-checkbox::after {
            transform: rotate(45deg) scale(1);
        }
        .cl-text {
            flex: 1;
            line-height: 1.5;
            color: var(--text);
            font-size: 0.9rem;
        }
        .cl-badge {
            font-size: 0.7rem;
            padding: 3px 8px;
            border-radius: 10px;
            font-weight: 600;
            flex-shrink: 0;
            letter-spacing: 0.03em;
        }
        .cl-badge.minimum {
            background: var(--red-soft);
            color: var(--red);
            animation: pulse-min 2.5s ease-in-out infinite;
        }
        @keyframes pulse-min {
            0%,
            100% {
                opacity: 0.8;
            }
            50% {
                opacity: 1;
            }
        }
        .cl-badge.core {
            background: var(--accent-soft);
            color: var(--accent);
        }

        /* MINIMUM ALERT */
        .minimum-alert {
            background: #FFF5F3;
            border: 1.5px solid #E07B6C40;
            border-radius: var(--radius-lg);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            font-weight: 600;
            font-size: 0.9rem;
            color: #C25445;
        }
        .minimum-alert .icon-shield {
            font-size: 1.6rem;
            flex-shrink: 0;
        }

        /* REWARD */
        .reward-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }
        @media (max-width: 500px) {
            .reward-grid {
                grid-template-columns: 1fr;
            }
        }
        .reward-card {
            background: #FAF9FD;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
            text-align: center;
            transition: var(--transition);
        }
        .reward-card:hover {
            border-color: var(--accent-glow);
        }
        .reward-days {
            font-size: 2rem;
            font-weight: 800;
            color: var(--accent);
            font-family: var(--font-mono);
            letter-spacing: -0.03em;
        }
        .reward-label {
            font-size: 0.8rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 2px;
        }
        .reward-desc {
            font-size: 0.85rem;
            color: var(--text);
            margin-top: 4px;
            min-height: 20px;
        }
        .reward-progress-mini {
            height: 4px;
            background: var(--border);
            border-radius: 4px;
            margin-top: 8px;
            overflow: hidden;
        }
        .reward-progress-mini-fill {
            height: 100%;
            background: var(--accent);
            border-radius: 4px;
            transition: width 0.5s;
        }

        /* ERROR */
        .error-list {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .error-list li {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            background: var(--bg);
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            font-size: 0.85rem;
        }
        .error-rank {
            font-weight: 800;
            color: var(--red);
            font-family: var(--font-mono);
            font-size: 0.9rem;
            flex-shrink: 0;
        }

        /* COLLAPSIBLE */
        .collapsible-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            padding: 6px 0;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }
        .collapsible-arrow {
            transition: transform 0.3s;
            font-size: 0.7rem;
            color: var(--text-secondary);
            flex-shrink: 0;
        }
        .collapsible.open .collapsible-arrow {
            transform: rotate(180deg);
        }
        .collapsible-body {
            overflow: hidden;
            max-height: 0;
            transition: max-height 0.4s ease, opacity 0.3s ease;
            opacity: 0;
        }
        .collapsible.open .collapsible-body {
            max-height: 6000px;
            opacity: 1;
        }

        /* FLOAT BUTTON */
        .float-btn {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 200;
            width: 54px;
            height: 54px;
            border-radius: 50%;
            background: var(--accent);
            color: #FFFFFF;
            border: none;
            cursor: pointer;
            font-size: 1.4rem;
            font-weight: 700;
            box-shadow: 0 6px 28px rgba(107, 91, 149, 0.4);
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .float-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 36px rgba(107, 91, 149, 0.5);
        }

        /* TOAST */
        .toast {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%) translateY(-120px);
            background: #FFFFFF;
            border: 1px solid var(--border-light);
            color: var(--text-heading);
            padding: 10px 20px;
            border-radius: 25px;
            font-size: 0.85rem;
            font-weight: 600;
            z-index: 300;
            transition: transform 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            pointer-events: none;
            box-shadow: var(--shadow-lg);
        }
        .toast.show {
            transform: translateX(-50%) translateY(0);
        }

        /* CELEBRATION */
        .celebrate-overlay {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 250;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .celebrate-text {
            font-size: 2rem;
            font-weight: 800;
            color: var(--accent);
            animation: celeb-pop 0.6s ease-out forwards;
            text-align: center;
            text-shadow: 0 0 30px rgba(107, 91, 149, 0.4);
        }
        @keyframes celeb-pop {
            0% {
                transform: scale(0.3);
                opacity: 0;
            }
            50% {
                transform: scale(1.15);
                opacity: 1;
            }
            100% {
                transform: scale(1);
                opacity: 0;
            }
        }

        /* CODE BLOCK */
        .code-block {
            background: #F5F3FA;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 14px 16px;
            font-family: var(--font-mono);
            font-size: 0.8rem;
            color: #2C2C3A;
            overflow-x: auto;
            white-space: pre-wrap;
            line-height: 1.6;
            position: relative;
        }
        .copy-btn-abs {
            position: absolute;
            top: 8px;
            right: 10px;
            background: #FFFFFF;
            border: 1px solid var(--border-light);
            color: var(--text-secondary);
            padding: 4px 12px;
            border-radius: 14px;
            cursor: pointer;
            font-size: 0.72rem;
            font-weight: 600;
            transition: var(--transition);
            font-family: var(--font-sans);
        }
        .copy-btn-abs:hover {
            background: var(--bg-elevated);
            color: var(--accent);
            border-color: var(--accent);
        }
        .copy-btn-abs.copied {
            background: var(--green-soft);
            border-color: var(--green);
            color: var(--green-bright);
        }

        /* EDITABLE */
        .editable-inline {
            display: inline-block;
            border-bottom: 1.5px dashed var(--border-light);
            padding: 2px 6px;
            cursor: text;
            min-width: 60px;
            color: var(--text-heading);
            transition: var(--transition);
            border-radius: 2px;
        }
        .editable-inline:focus {
            outline: none;
            border-bottom-color: var(--accent);
            background: rgba(107, 91, 149, 0.03);
        }
        .editable-inline:empty::before {
            content: '点击填写';
            color: var(--text-secondary);
            font-style: italic;
        }

        /* MISC */
        .text-accent {
            color: var(--accent);
            font-weight: 600;
        }
        .text-green {
            color: var(--green-bright);
        }
        .text-red {
            color: var(--red);
        }
        .text-sm {
            font-size: 0.82rem;
        }
        .text-xs {
            font-size: 0.72rem;
        }
        .text-mono {
            font-family: var(--font-mono);
        }
        .mt-8 {
            margin-top: 8px;
        }
        .mt-12 {
            margin-top: 12px;
        }
        .mt-16 {
            margin-top: 16px;
        }
        .mb-8 {
            margin-bottom: 8px;
        }
        .mb-12 {
            margin-bottom: 12px;
        }
        .flex-row {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }
        .divider {
            border: none;
