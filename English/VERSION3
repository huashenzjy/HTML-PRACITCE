    <!-- Firebase + 主逻辑 Module -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-app.js";
        import { getAuth, GoogleAuthProvider, signInWithPopup, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-auth.js";
        import { getFirestore, doc, getDoc, setDoc, serverTimestamp } from "https://www.gstatic.com/firebasejs/12.13.0/firebase-firestore.js";

        const firebaseConfig = {
            apiKey: "AIzaSyDp1Dl78ovJ7X8lKOCe9WYIvsPrnT2oyxc",
            authDomain: "sdet-tracker.firebaseapp.com",
            projectId: "sdet-tracker",
            storageBucket: "sdet-tracker.firebasestorage.app",
            messagingSenderId: "491562975282",
            appId: "1:491562975282:web:260e9e7008b4e9acc53c2b",
            measurementId: "G-0YJT8P87JC"
        };

        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        const provider = new GoogleAuthProvider();

        const STORAGE_KEY = 'engB1B2_learningPanel';
        const FIRESTORE_COLLECTION = 'learningPanels';
        const todayStr = getDateStr(new Date());
        const dayOfWeek = new Date().getDay();

        let appData = getDefaultData();
        let currentUser = null;
        let syncState = 'offline';
        let lastSyncTime = null;
        let syncDebounceTimer = null;
        const SYNC_DEBOUNCE_MS = 2500;

        // DOM Refs
        const $ = (id) => document.getElementById(id);
        const $checklist = $('checklist');
        const $progressBar = $('progressBar');
        const $progressPct = $('progressPct');
        const $streakNum = $('streakNum');
        const $streakBadge = $('streakBadge');
        const $statusDot = $('statusDot');
        const $statusLabel = $('statusLabel');
        const $completionSummary = $('completionSummary');
        const $heroDayType = $('heroDayType');
        const $heroDate = $('heroDate');
        const $taskHeading = $('taskHeading');
        const $toast = $('toast');
        const $celebrateOverlay = $('celebrateOverlay');
        const $copyPromptBtn = $('copyPromptBtn');
        const $reward30Days = $('reward30Days');
        const $reward60Days = $('reward60Days');
        const $reward30Bar = $('reward30Bar');
        const $reward60Bar = $('reward60Bar');
        const $reward30Desc = $('reward30Desc');
        const $reward60Desc = $('reward60Desc');
        const $progressWrap = $('progressWrap');
        const $syncDot = $('syncDot');
        const $syncLabel = $('syncLabel');
        const $btnSync = $('btnSync');
        const $userArea = $('userArea');

        function getDefaultData() {
            return {
                startDate: '2026-05-14',
                completedDates: [],
                taskChecks: {},
                threeThings: {},
                errors: { err1: '', err2: '', err3: '' },
                commitTime: '',
                commitPlace: '',
                reward30: '',
                reward60: '',
                lastUpdated: null
            };
        }

        function loadLocalData() {
            try {
                const raw = localStorage.getItem(STORAGE_KEY);
                if (raw) {
                    const parsed = JSON.parse(raw);
                    const defaults = getDefaultData();
                    for (const k in defaults) { if (!(k in parsed)) parsed[k] = defaults[k]; }
                    return parsed;
                }
            } catch (e) {}
            return getDefaultData();
        }

        function saveLocalData(data) {
            data.lastUpdated = new Date().toISOString();
            localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
        }

        function getUserDocRef() {
            if (!currentUser) return null;
            return doc(db, FIRESTORE_COLLECTION, currentUser.uid);
        }

        async function saveToCloud(data) {
            if (!currentUser || !db) return;
            const docRef = getUserDocRef();
            if (!docRef) return;
            try {
                setSyncState('syncing');
                await setDoc(docRef, { ...data, _cloudUpdated: serverTimestamp() }, { merge: true });
                lastSyncTime = new Date();
                setSyncState('synced');
            } catch (e) {
                console.warn('云同步失败', e);
                setSyncState('error');
            }
        }

        async function loadFromCloud() {
            if (!currentUser || !db) return null;
            const docRef = getUserDocRef();
            if (!docRef) return null;
            try {
                setSyncState('syncing');
                const snap = await getDoc(docRef);
                if (snap.exists()) {
                    const data = snap.data();
                    delete data._cloudUpdated;
                    const defaults = getDefaultData();
                    for (const k in defaults) { if (!(k in data)) data[k] = defaults[k]; }
                    lastSyncTime = new Date();
                    setSyncState('synced');
                    return data;
                }
                setSyncState('synced');
                return null;
            } catch (e) {
                console.warn('云端加载失败', e);
                setSyncState('error');
                return null;
            }
        }

        function mergeData(local, cloud) {
            if (!cloud) return local;
            if (!local || !local.lastUpdated) return cloud;
            if (!cloud.lastUpdated) return local;
            const lt = new Date(local.lastUpdated).getTime();
            const ct = new Date(cloud.lastUpdated).getTime();
            if (ct > lt) return cloud;
            if (lt > ct) return local;
            const merged = { ...cloud, ...local };
            merged.completedDates = [...new Set([...(cloud.completedDates || []), ...(local.completedDates || [])])].sort();
            merged.taskChecks = { ...(cloud.taskChecks || {}), ...(local.taskChecks || {}) };
            merged.threeThings = { ...(cloud.threeThings || {}), ...(local.threeThings || {}) };
            merged.errors = { ...(cloud.errors || {}), ...(local.errors || {}) };
            return merged;
        }

        function setSyncState(state) {
            syncState = state;
            $syncDot.className = 'sync-dot ' + state;
            const labels = { offline: '离线', syncing: '同步中…', synced: '已同步', error: '同步失败' };
            $syncLabel.textContent = labels[state] || state;
            $btnSync.textContent = state === 'syncing' ? '⏳ 同步中' : '☁️ 同步';
        }

        function scheduleCloudSave() {
            if (syncDebounceTimer) clearTimeout(syncDebounceTimer);
            syncDebounceTimer = setTimeout(() => saveToCloud(appData), SYNC_DEBOUNCE_MS);
        }

        function saveData(data) {
            appData = data;
            saveLocalData(data);
            scheduleCloudSave();
        }

        async function manualSync() {
            if (!currentUser) {
                showToast('请先登录 Google 账号');
                return;
            }
            showToast('☁️ 正在同步…');
            const cloudData = await loadFromCloud();
            if (cloudData) {
                const merged = mergeData(appData, cloudData);
                if (JSON.stringify(merged) !== JSON.stringify(appData)) {
                    appData = merged;
                    saveLocalData(appData);
                    renderChecklist();
                    updateAllUI();
                    showToast('✅ 已同步最新数据');
                } else {
                    await saveToCloud(appData);
                    showToast('✅ 数据已同步');
                }
            } else if (syncState === 'error') {
                showToast('❌ 同步失败，请重试');
            } else {
                await saveToCloud(appData);
                showToast('✅ 数据已上传云端');
            }
        }

        // Google 登录 / 登出
        async function googleLogin() {
            try {
                const result = await signInWithPopup(auth, provider);
                currentUser = result.user;
                updateUserUI();
                showToast('✅ 已登录：' + currentUser.displayName);
                await initCloudSync();
            } catch (e) {
                console.error('登录失败', e);
                showToast('❌ 登录失败，请重试');
            }
        }

        async function googleLogout() {
            await signOut(auth);
            currentUser = null;
            updateUserUI();
            setSyncState('offline');
            showToast('👋 已退出登录，数据保留在本地');
        }

        function updateUserUI() {
            if (currentUser) {
                $userArea.innerHTML = `
                    <span class="user-info">
                        <img class="user-avatar" src="${currentUser.photoURL || ''}" alt="">
                        <span>${currentUser.displayName || '用户'}</span>
                    </span>
                    <button class="btn btn-sm btn-outline" onclick="window._googleLogout()">退出</button>
                `;
            } else {
                $userArea.innerHTML = `<button class="btn-login" onclick="window._googleLogin()"><span style="font-size:1.1rem;">G</span> 使用 Google 登录</button>`;
            }
        }

        async function initCloudSync() {
            if (!currentUser) return;
            const cloudData = await loadFromCloud();
            if (cloudData) {
                const merged = mergeData(appData, cloudData);
                if (JSON.stringify(merged) !== JSON.stringify(appData)) {
                    appData = merged;
                    saveLocalData(appData);
                    renderChecklist();
                    updateAllUI();
                }
            } else if (!cloudData && syncState !== 'error') {
                await saveToCloud(appData);
            }
        }

        // 其余功能函数
        function getDateStr(d) { const y = d.getFullYear(); const m = String(d.getMonth() + 1).padStart(2, '0'); const day = String(d.getDate()).padStart(2, '0'); return `${y}-${m}-${day}`; }

        function calcStreak(dates) {
            if (!dates || dates.length === 0) return 0;
            const sorted = [...new Set(dates)].sort().reverse();
            const today = getDateStr(new Date());
            const yest = (() => { const d = new Date();
                d.setDate(d.getDate() - 1); return getDateStr(d); })();
            let ref = null;
            if (sorted[0] === today) ref = today;
            else if (sorted[0] === yest) ref = yest;
            else if (sorted.includes(yest)) ref = yest;
            else return 0;
            if (!ref) return 0;
            let streak = 0;
            const check = new Date(ref);
            for (const s of sorted) {
                if (s === getDateStr(check)) { streak++;
                    check.setDate(check.getDate() - 1); } else if (s < getDateStr(check)) break;
            }
            return streak;
        }

        function isTodayCompleted() { return appData.completedDates.includes(todayStr); }

        function getTodayTaskChecks() { return appData.taskChecks[todayStr] || {}; }

        function setTodayTaskCheck(taskId, checked) {
            if (!appData.taskChecks[todayStr]) appData.taskChecks[todayStr] = {};
            if (checked) appData.taskChecks[todayStr][taskId] = true;
            else delete appData.taskChecks[todayStr][taskId];
            if (Object.keys(appData.taskChecks[todayStr]).length === 0) delete appData.taskChecks[todayStr];
            saveData(appData);
            updateAllUI();
        }

        function getTodayTaskCount() { return document.querySelectorAll('#checklist li[data-task-id]').length; }

        function getTodayCheckedCount() {
            const checks = getTodayTaskChecks();
            let c = 0;
            document.querySelectorAll('#checklist li[data-task-id]').forEach(li => { if (checks[li.dataset.taskId]) c++; });
            return c;
        }

        function getDayTypeInfo() {
            const m = { 0: { type: '复盘 + 备料日', emoji: '📋', heading: '周日复盘 & 备料流程' }, 1: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程' }, 2: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程' }, 3: { type: '语法专项日', emoji: '🔬', heading: '周三语法专项流程' }, 4: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程' }, 5: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程' }, 6: { type: '写作日', emoji: '✍️', heading: '周六写作日流程' } };
            return m[dayOfWeek] || m[1];
        }

        function getTasksForDay() {
            const d = {
                0: [{ id: 'sun1', text: '本周错误总结', time: '10分钟', badge: 'core' }, { id: 'sun2', text: '准备下周材料', time: '10分钟', badge: 'core' }, { id: 'sun3', text: '最低底线：至少准备3篇材料', time: '5分钟', badge: 'minimum' }],
                3: [{ id: 'wed1', text: '找出本周最高频错误', time: '5分钟', badge: 'core' }, { id: 'wed2', text: '读对应Grammar in Use Unit', time: '10分钟', badge: 'core' }, { id: 'wed3', text: '造8个句子发AI校对', time: '10分钟', badge: 'core' }, { id: 'wed4', text: '最低底线：读1个Unit造3句', time: '5分钟', badge: 'minimum' }],
                6: [{ id: 'sat1', text: '写150–200字短文', time: '20分钟', badge: 'core' }, { id: 'sat2', text: '自查+AI校对', time: '10分钟', badge: 'core' }, { id: 'sat3', text: '最低底线：写80字短文', time: '10分钟', badge: 'minimum' }]
            };
            const def = [{ id: 't1', text: '昨日错误回顾', time: '5分钟', badge: 'core' }, { id: 't2', text: '裸翻训练（核心）', time: '10分钟', badge: 'core' }, { id: 't3', text: '自查', time: '5分钟', badge: 'core' }, { id: 't4', text: 'AI对比+记录错误', time: '5分钟', badge: 'core' }, { id: 't5', text: '最低底线：翻译5句话', time: '5分钟', badge: 'minimum' }];
            return d[dayOfWeek] || def;
        }

        function renderChecklist() {
            const tasks = getTasksForDay();
            const checks = getTodayTaskChecks();
            $checklist.innerHTML = '';
            tasks.forEach(t => {
                const li = document.createElement('li');
                li.dataset.taskId = t.id;
                if (checks[t.id]) li.classList.add('checked');
                li.innerHTML = `<span class="cl-checkbox"></span><span class="cl-text">${t.text}</span><span class="cl-badge ${t.badge}">${t.time}</span>`;
                li.addEventListener('click', () => {
                    const cur = li.classList.contains('checked');
                    if (cur) { li.classList.remove('checked');
                        setTodayTaskCheck(t.id, false); } else { li.classList.add('checked');
                        setTodayTaskCheck(t.id, true); if (getTodayCheckedCount() >= getTodayTaskCount() && getTodayTaskCount() > 0) markDayCompleted(); }
                });
                $checklist.appendChild(li);
            });
            updateCompletionSummary();
        }

        function updateCompletionSummary() {
            const total = getTodayTaskCount();
            const checked = getTodayCheckedCount();
            $completionSummary.textContent = `完成 ${checked} / ${total} 项`;
            const pct = total > 0 ? Math.round((checked / total) * 100) : 0;
            $progressPct.textContent = pct + '%';
            $progressBar.style.width = pct + '%';
            if (pct === 0 && !isTodayCompleted()) setStatus('idle', '未开始');
            else if (pct >= 100 || isTodayCompleted()) setStatus('done', '已完成');
            else setStatus('active', '进行中');
        }

        function setStatus(state, label) { $statusDot.className = 'status-dot ' + state;
            $statusLabel.textContent = label; }

        function markDayCompleted() {
            if (!appData.completedDates.includes(todayStr)) { appData.completedDates.push(todayStr);
                appData.completedDates.sort();
                saveData(appData);
                showCelebration();
                showToast('🎉 太棒了！今日任务全部完成！'); }
            updateAllUI();
        }

        function showCelebration() {
            $celebrateOverlay.style.display = 'flex';
            $celebrateOverlay.innerHTML = '<span class="celebrate-text">🔥 今日完成！<br><small style="font-size:0.6em;">坚持就是胜利</small></span>';
            setTimeout(() => { $celebrateOverlay.style.display = 'none';
                $celebrateOverlay.innerHTML = ''; }, 1800);
        }

        function updateAllUI() {
            const streak = calcStreak(appData.completedDates);
            $streakNum.textContent = streak;
            $streakBadge.classList.toggle('broken', streak === 0 && appData.completedDates.length > 0);
            updateCompletionSummary();
            updateRewards();
            updateHeroDate();
            updateThreeThingsUI();
            updateEditableFields();
            updateErrorFields();
        }

        function updateHeroDate() {
            const info = getDayTypeInfo();
            $heroDate.textContent = new Date().toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric', weekday: 'long' });
            $heroDayType.textContent = info.emoji + ' ' + info.type;
            $taskHeading.textContent = info.heading;
        }

        function updateRewards() {
            const cnt = appData.completedDates.length;
            $reward30Days.textContent = Math.min(cnt, 30) + '/30';
            $reward60Days.textContent = Math.min(cnt, 60) + '/60';
            $reward30Bar.style.width = Math.min(100, Math.round((cnt / 30) * 100)) + '%';
            $reward60Bar.style.width = Math.min(100, Math.round((cnt / 60) * 100)) + '%';
            $reward30Desc.textContent = appData.reward30 || '设置你的奖励';
            $reward60Desc.textContent = appData.reward60 || '设置你的奖励';
            if (cnt >= 30) { $reward30Days.style.color = 'var(--green-bright)';
                $reward30Bar.style.background = 'var(--green-bright)'; }
            if (cnt >= 60) { $reward60Days.style.color = 'var(--green-bright)';
                $reward60Bar.style.background = 'var(--green-bright)'; }
        }

        function updateThreeThingsUI() {
            document.querySelectorAll('#threeThingsList li').forEach(li => li.classList.toggle('checked', appData.threeThings[li.dataset.id]));
        }

        function updateEditableFields() {
            ['commitTime', 'commitPlace', 'reward30', 'reward60'].forEach(k => { const el = $(k); if (el && appData[k]) el.textContent = appData[k]; });
        }

        function updateErrorFields() {
            ['err1', 'err2', 'err3'].forEach(k => { const el = document.querySelector(`[data-key="${k}"]`); if (el && appData.errors[k]) el.textContent = appData.errors[k]; });
        }

        function scrollToTasks() { const el = $('taskCard'); if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                el.style.boxShadow = '0 0 0 4px var(--accent-glow)';
                setTimeout(() => el.style.boxShadow = '', 1200); } }

        function scrollToMinimal() { const el = $('minimumSection'); if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' }); }

        function markAllDone() {
            getTasksForDay().forEach(t => { if (!appData.taskChecks[todayStr]) appData.taskChecks[todayStr] = {};
                appData.taskChecks[todayStr][t.id] = true; });
            if (!appData.completedDates.includes(todayStr)) { appData.completedDates.push(todayStr);
                appData.completedDates.sort(); }
            saveData(appData);
            renderChecklist();
            updateAllUI();
            showCelebration();
            showToast('✅ 今日已全部标记完成！');
        }

        function resetToday() {
            if (appData.taskChecks[todayStr]) delete appData.taskChecks[todayStr];
            appData.completedDates = appData.completedDates.filter(d => d !== todayStr);
            saveData(appData);
            renderChecklist();
            updateAllUI();
            setStatus('idle', '未开始');
            showToast('🔄 今日进度已重置');
        }

        function toggleThing(li) {
            appData.threeThings[li.dataset.id] = !appData.threeThings[li.dataset.id];
            saveData(appData);
            updateThreeThingsUI();
        }

        function copyPrompt() {
            navigator.clipboard.writeText($('promptCode').textContent.trim()).then(() => {
                $copyPromptBtn.textContent = '✓ 已复制';
                $copyPromptBtn.classList.add('copied');
                showToast('📋 提示词已复制');
                setTimeout(() => { $copyPromptBtn.textContent = '📋 复制';
                    $copyPromptBtn.classList.remove('copied'); }, 2000);
            }).catch(() => showToast('⚠️ 复制失败'));
        }

        function clearErrors() {
            appData.errors = { err1: '', err2: '', err3: '' };
            saveData(appData);
            document.querySelectorAll('#errorTop3 .editable-inline').forEach(el => { el.textContent = el.dataset.key === 'err1' ? '点击填写最高频错误' : el.dataset.key === 'err2' ? '点击填写第二高频错误' : '点击填写第三高频错误'; });
            showToast('🗑️ 错误记录已清空');
        }

        function clearAllData() {
            if (confirm('确定清除所有本地和云端数据吗？')) {
                localStorage.removeItem(STORAGE_KEY);
                appData = getDefaultData();
                saveData(appData);
                renderChecklist();
                updateAllUI();
                setStatus('idle', '未开始');
                showToast('⚠️ 所有数据已清除');
            }
        }

        function resetStreak() {
            if (confirm('重置连续打卡记录？')) { appData.completedDates = [];
                appData.taskChecks = {};
                saveData(appData);
                renderChecklist();
                updateAllUI();
                setStatus('idle', '未开始');
                showToast('🔄 Streak 已重置'); }
        }

        function exportData() {
            const blob = new Blob([JSON.stringify(appData, null, 2)], { type: 'application/json' });
            const a = document.createElement('a');
            a.href = URL.createObjectURL(blob);
            a.download = `eng-b1-b2-backup-${todayStr}.json`;
            a.click();
            showToast('📥 数据已导出');
        }

        function importData() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            input.onchange = e => {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = ev => {
                    try {
                        const imported = JSON.parse(ev.target.result);
                        const defaults = getDefaultData();
                        for (const k in defaults) if (!(k in imported)) imported[k] = defaults[k];
                        appData = imported;
                        saveData(appData);
                        renderChecklist();
                        updateAllUI();
                        showToast('📤 数据已导入');
                    } catch { showToast('❌ 文件格式错误'); }
                };
                reader.readAsText(file);
            };
            input.click();
        }

        function showToast(msg) {
            $toast.textContent = msg;
            $toast.classList.add('show');
            clearTimeout($toast._timeout);
            $toast._timeout = setTimeout(() => $toast.classList.remove('show'), 2200);
        }

        function toggleCollapsible(el) { el.classList.toggle('open'); }

        function setupEditableListeners() {
            document.querySelectorAll('.editable-inline[data-key]').forEach(el => {
                el.addEventListener('blur', () => {
                    const key = el.dataset.key;
                    const text = el.textContent.trim();
                    if (['err1', 'err2', 'err3'].includes(key)) appData.errors[key] = text;
                    else appData[key] = text;
                    saveData(appData);
                    if (key === 'reward30' || key === 'reward60') updateRewards();
                });
                el.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault();
                        el.blur(); } });
            });
        }

        window.addEventListener('scroll', () => $progressWrap.classList.toggle('scrolled', window.scrollY > 50));

        // 全局暴露
        window.scrollToTasks = scrollToTasks;
        window.scrollToMinimal = scrollToMinimal;
        window.markAllDone = markAllDone;
        window.resetToday = resetToday;
        window.toggleThing = toggleThing;
        window.copyPrompt = copyPrompt;
        window.clearErrors = clearErrors;
        window.clearAllData = clearAllData;
        window.resetStreak = resetStreak;
        window.toggleCollapsible = toggleCollapsible;
        window.manualSync = manualSync;
        window.exportData = exportData;
        window.importData = importData;
        window._googleLogin = googleLogin;
        window._googleLogout = googleLogout;

        // 初始化
        async function init() {
            appData = loadLocalData();
            renderChecklist();
            updateAllUI();
            updateHeroDate();
            setupEditableListeners();
            updateEditableFields();
            updateErrorFields();
            if (isTodayCompleted()) {
                setStatus('done', '已完成');
                const tasks = getTasksForDay();
                if (!appData.taskChecks[todayStr]) appData.taskChecks[todayStr] = {};
                tasks.forEach(t => { appData.taskChecks[todayStr][t.id] = true; });
                saveLocalData(appData);
                renderChecklist();
                updateCompletionSummary();
            }

            onAuthStateChanged(auth, async (user) => {
                currentUser = user;
                updateUserUI();
                if (user) {
                    await initCloudSync();
                } else {
                    setSyncState('offline');
                }
            });
        }

        init();
    </script>
</body>
</html>