            // 相同时间，合并（保留更完整的）
            const merged = { ...cloudData, ...localData };
            merged.completedDates = [...new Set([...(cloudData.completedDates || []), ...(localData.completedDates || [])])].sort();
            merged.taskChecks = { ...(cloudData.taskChecks || {}), ...(localData.taskChecks || {}) };
            merged.threeThings = { ...(cloudData.threeThings || {}), ...(localData.threeThings || {}) };
            merged.errors = { ...(cloudData.errors || {}), ...(localData.errors || {}) };
            return merged;
        }

        function setSyncState(state) {
            syncState = state;
            $syncDot.className = 'sync-dot ' + state;
            const labels = { offline: '离线', syncing: '同步中…', synced: '已同步', error: '同步失败' };
            $syncLabel.textContent = labels[state] || state;
            if (state === 'syncing') {
                $btnSync.textContent = '⏳ 同步中';
                $btnSync.style.opacity = '0.7';
            } else if (state === 'error') {
                $btnSync.textContent = '⚠️ 重试';
                $btnSync.style.opacity = '1';
            } else {
                $btnSync.textContent = '☁️ 同步';
                $btnSync.style.opacity = '1';
            }
        }

        function updateSyncTimeDisplay() {
            if (lastSyncTime) {
                const timeStr = lastSyncTime.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
                $syncTime.textContent = timeStr;
            } else {
                $syncTime.textContent = '';
            }
        }

        // Debounced cloud save
        function scheduleCloudSave() {
            if (syncDebounceTimer) clearTimeout(syncDebounceTimer);
            syncDebounceTimer = setTimeout(async () => {
                await saveToCloud(appData);
            }, SYNC_DEBOUNCE_MS);
        }

        // ============ SAVE DATA (local + cloud) ============
        function saveData(data) {
            appData = data;
            saveLocalData(data);
            scheduleCloudSave(); // 自动推送到云端（debounced）
        }

        // ============ MANUAL SYNC ============
        async function manualSync() {
            if (!currentUser) {
                showToast('⚠️ 尚未登录，正在尝试匿名登录…');
                await initAuth();
                if (!currentUser) {
                    showToast('❌ 无法连接云端，请检查网络');
                    return;
                }
            }
            showToast('☁️ 正在同步…');
            const cloudData = await loadFromCloud();
            if (cloudData) {
                const merged = mergeData(appData, cloudData);
                if (JSON.stringify(merged) !== JSON.stringify(appData)) {
                    appData = merged;
                    saveLocalData(appData);
                    renderChecklist();
                    updateAllUI();
                    showToast('✅ 已从云端同步最新数据');
                } else {
                    // 本地和云端一致，推送本地到云端确保一致
                    await saveToCloud(appData);
                    showToast('✅ 数据已同步');
                }
            } else if (syncState === 'error') {
                showToast('❌ 同步失败，请稍后重试');
            } else {
                // 云端无数据，推送本地
                await saveToCloud(appData);
                showToast('✅ 本地数据已上传云端');
            }
        }

        // ============ AUTH ============
        async function initAuth() {
            return new Promise((resolve) => {
                // 先检查是否已有认证状态
                const unsubscribe = onAuthStateChanged(auth, async (user) => {
                    unsubscribe();
                    if (user) {
                        currentUser = user;
                        console.log('🔑 已认证用户:', user.uid);
                        setSyncState('synced');
                        resolve(user);
                    } else {
                        // 尝试匿名登录
                        try {
                            const credential = await signInAnonymously(auth);
                            currentUser = credential.user;
                            console.log('🔑 匿名登录成功:', currentUser.uid);
                            setSyncState('synced');
                            resolve(currentUser);
                        } catch (err) {
                            console.warn('🔑 匿名登录失败:', err.message);
                            currentUser = null;
                            setSyncState('offline');
                            resolve(null);
                        }
                    }
                });
                // 超时处理：3秒后仍未触发则标记离线
                setTimeout(() => {
                    if (!currentUser && syncState === 'offline') {
                        setSyncState('offline');
                        resolve(null);
                    }
                }, 3000);
            });
        }

        // ============ HELPERS ============
        function getDateStr(date) {
            const y = date.getFullYear();
            const m = String(date.getMonth() + 1).padStart(2, '0');
            const d = String(date.getDate()).padStart(2, '0');
            return `${y}-${m}-${d}`;
        }

        function calcStreak(completedDates) {
            if (!completedDates || completedDates.length === 0) return 0;
            const sorted = [...new Set(completedDates)].sort().reverse();
            const today = getDateStr(new Date());
            const yesterday = (() => { const d = new Date();
                d.setDate(d.getDate() - 1); return getDateStr(d); })();
            let startRef = null;
            if (sorted[0] === today) startRef = today;
            else if (sorted[0] === yesterday) startRef = yesterday;
            else if (sorted.includes(yesterday)) startRef = yesterday;
            else return 0;
            if (!startRef) return 0;
            let streak = 0;
            const checkDate = new Date(startRef);
            for (const s of sorted) {
                const expected = getDateStr(checkDate);
                if (s === expected) { streak++;
                    checkDate.setDate(checkDate.getDate() - 1); } else if (s < expected) break;
            }
            return streak;
        }

        function isTodayCompleted() { return appData.completedDates.includes(todayStr); }

        function getTodayTaskChecks() { return appData.taskChecks[todayStr] || {}; }

        function setTodayTaskCheck(taskId, checked) {
            if (!appData.taskChecks[todayStr]) appData.taskChecks[todayStr] = {};
            if (checked) appData.taskChecks[todayStr][taskId] = true;
            else delete appData.taskChecks[todayStr][taskId];
            if (Object.keys(appData.taskChecks[todayStr]).length === 0) delete appData.taskChecks[todayStr];
            saveData(appData);
            updateAllUI();
        }

        function getTodayTaskCount() { return document.querySelectorAll('#checklist li[data-task-id]').length; }

        function getTodayCheckedCount() {
            const checks = getTodayTaskChecks();
            let count = 0;
            document.querySelectorAll('#checklist li[data-task-id]').forEach(li => { if (checks[li.dataset.taskId]) count++; });
            return count;
        }

        // ============ DAY TYPE ============
        function getDayTypeInfo() {
            const map = {
                0: { type: '复盘 + 备料日', emoji: '📋', heading: '周日复盘 & 备料流程', color: 'var(--green-bright)' },
                1: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程', color: 'var(--accent)' },
                2: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程', color: 'var(--accent)' },
                3: { type: '语法专项日', emoji: '🔬', heading: '周三语法专项流程', color: 'var(--orange)' },
                4: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程', color: 'var(--accent)' },
                5: { type: '翻译训练日', emoji: '📝', heading: '翻译训练日流程', color: 'var(--accent)' },
                6: { type: '写作日', emoji: '✍️', heading: '周六写作日流程', color: 'var(--blue)' },
            };
            return map[dayOfWeek] || map[1];
        }

        function getTasksForDay() {
            const dayMap = {
                0: [
                    { id: 'sun1', text: '本周错误总结——翻 Obsidian 错误记录', time: '10分钟', badge: 'core' },
                    { id: 'sun2', text: '准备下周材料——找5篇VOA故事AI翻中文', time: '10分钟', badge: 'core' },
                    { id: 'sun3', text: '最低底线：至少准备好下周3篇材料', time: '5分钟', badge: 'minimum' },
                ],
                3: [
                    { id: 'wed1', text: '找出本周最高频错误', time: '5分钟', badge: 'core' },
                    { id: 'wed2', text: '读对应Grammar in Use Unit', time: '10分钟', badge: 'core' },
                    { id: 'wed3', text: '造8个句子发AI校对', time: '10分钟', badge: 'core' },
                    { id: 'wed4', text: '最低底线：至少读1个Unit造3个句子', time: '5分钟', badge: 'minimum' },
                ],
                6: [
                    { id: 'sat1', text: '写150–200字短文含定语和状语从句', time: '20分钟', badge: 'core' },
                    { id: 'sat2', text: '自查+AI校对', time: '10分钟', badge: 'core' },
                    { id: 'sat3', text: '最低底线：写80字短文发AI校对', time: '10分钟', badge: 'minimum' },
                ],
            };
            const defaultTasks = [
                { id: 't1', text: '昨日错误回顾——打开Obsidian看昨天2–3个错误句子', time: '5分钟', badge: 'core' },
                { id: 't2', text: '裸翻训练（核心）——看中文版直接打出英文', time: '10分钟', badge: 'core' },
                { id: 't3', text: '自查——检查动词形式、过去完成时、从句引导词', time: '5分钟', badge: 'core' },
                { id: 't4', text: 'AI对比+记录错误', time: '5分钟', badge: 'core' },
                { id: 't5', text: '最低底线：翻译5句话5分钟内结束（不可破）', time: '5分钟', badge: 'minimum' },
            ];
            return dayMap[dayOfWeek] || defaultTasks;
        }

        // ============ RENDER ============
        function renderChecklist() {
            const tasks = getTasksForDay();
            const checks = getTodayTaskChecks();
            $checklist.innerHTML = '';
            tasks.forEach(task => {
                const li = document.createElement('li');
                li.dataset.taskId = task.id;
                if (checks[task.id]) li.classList.add('checked');
                li.innerHTML =
                    `<span class="cl-checkbox"></span><span class="cl-text">${task.text}</span><span class="cl-badge ${task.badge}">${task.time}</span>`;
                li.addEventListener('click', () => {
                    const cur = li.classList.contains('checked');
                    if (cur) { li.classList.remove('checked');
                        setTodayTaskCheck(task.id, false); } else { li.classList.add('checked');
                        setTodayTaskCheck(task.id, true); if (getTodayCheckedCount() >= getTodayTaskCount() &&
                            getTodayTaskCount() > 0) markDayCompleted(); }
                });
                $checklist.appendChild(li);
            });
            updateCompletionSummary();
        }

        function updateCompletionSummary() {
            const total = getTodayTaskCount();
            const checked = getTodayCheckedCount();
            $completionSummary.textContent = `完成 ${checked} / ${total} 项`;
            const pct = total > 0 ? Math.round((checked / total) * 100) : 0;
            $progressPct.textContent = pct + '%';
            $progressBar.style.width = pct + '%';
            if (pct === 0 && !isTodayCompleted()) setStatus('idle', '未开始');
            else if (pct >= 100 || isTodayCompleted()) setStatus('done', '已完成');
            else setStatus('active', '进行中');
        }

        function setStatus(state, label) {
            $statusDot.className = 'status-dot ' + state;
            $statusLabel.textContent = label;
        }

        function markDayCompleted() {
            if (!appData.completedDates.includes(todayStr)) {
                appData.completedDates.push(todayStr);
                appData.completedDates.sort();
                saveData(appData);
                showCelebration();
                showToast('🎉 太棒了！今日任务全部完成！');
            }
            updateAllUI();
        }

        function showCelebration() {
            const overlay = $celebrateOverlay;
            overlay.style.display = 'flex';
            overlay.innerHTML =
                '<span class="celebrate-text">🔥 今日完成！<br><small style="font-size:0.6em;">坚持就是胜利</small></span>';
            setTimeout(() => { overlay.style.display = 'none';
                overlay.innerHTML = ''; }, 1800);
        }

        function updateAllUI() {
            const streak = calcStreak(appData.completedDates);
            $streakNum.textContent = streak;
            if (streak === 0 && appData.completedDates.length === 0) $streakBadge.classList.remove('broken');
            else if (streak === 0 && appData.completedDates.length > 0) { $streakBadge.classList.add('broken');
                $streakNum.textContent = '0'; } else $streakBadge.classList.remove('broken');
            updateCompletionSummary();
            updateRewards();
            updateHeroDate();
            updateThreeThingsUI();
            updateEditableFields();
            updateErrorFields();
        }

        function updateHeroDate() {
            const info = getDayTypeInfo();
            const now = new Date();
            $heroDate.textContent = now.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric',
                weekday: 'long' });
            $heroDayType.textContent = info.emoji + ' ' + info.type;
            $taskHeading.textContent = info.heading;
        }

        function updateRewards() {
            const count = appData.completedDates.length;
            $reward30Days.textContent = Math.min(count, 30) + '/30';
            $reward60Days.textContent = Math.min(count, 60) + '/60';
            $reward30Bar.style.width = Math.min(100, Math.round((count / 30) * 100)) + '%';
            $reward60Bar.style.width = Math.min(100, Math.round((count / 60) * 100)) + '%';
            $reward30Desc.textContent = appData.reward30 || '设置你的奖励';
            $reward60Desc.textContent = appData.reward60 || '设置你的奖励';
            if (count >= 30) { $reward30Days.style.color = 'var(--green-bright)';
                $reward30Bar.style.background = 'var(--green-bright)'; }
            if (count >= 60) { $reward60Days.style.color = 'var(--green-bright)';
                $reward60Bar.style.background = 'var(--green-bright)'; }
        }

        function updateThreeThingsUI() {
            document.querySelectorAll('#threeThingsList li').forEach(li => {
                if (appData.threeThings[li.dataset.id]) li.classList.add('checked');
                else li.classList.remove('checked');
            });
        }

        function updateEditableFields() {
            ['commitTime', 'commitPlace', 'reward30', 'reward60'].forEach(key => {
                const el = document.getElementById(key);
                if (el && appData[key]) el.textContent = appData[key];
            });
        }

        function updateErrorFields() {
            ['err1', 'err2', 'err3'].forEach(key => {
                const el = document.querySelector(`[data-key="${key}"]`);
                if (el && appData.errors[key]) el.textContent = appData.errors[key];
            });
        }

        // ============ ACTIONS ============
        function scrollToTasks() {
            const el = document.getElementById('taskCard');
            if (el) { el.scrollIntoView({ behavior: 'smooth', block: 'center' });
                el.style.boxShadow = '0 0 0 4px var(--accent-glow)';
                setTimeout(() => { el.style.boxShadow = ''; }, 1200); }
        }

        function scrollToMinimal() {
            const el = document.getElementById('minimumSection');
            if (el) el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function markAllDone() {
            getTasksForDay().forEach(t => {
                if (!appData.taskChecks[todayStr]) appData.taskChecks[todayStr] = {};
                appData.taskChecks[todayStr][t.id] = true;
            });
            if (!appData.completedDates.includes(todayStr)) { appData.completedDates.push(todayStr);
                appData.completedDates.sort(); }
            saveData(appData);
            renderChecklist();
            updateAllUI();
            showCelebration();
            showToast('✅ 今日已全部标记完成！');
        }

        function resetToday() {
            if (appData.taskChecks[todayStr]) delete appData.taskChecks[todayStr];
            appData.completedDates = appData.completedDates.filter(d => d !== todayStr);
            saveData(appData);
            renderChecklist();
            updateAllUI();
            setStatus('idle', '未开始');
            showToast('🔄 今日进度已重置');
        }

        function toggleThing(li) {
            appData.threeThings[li.dataset.id] = !appData.threeThings[li.dataset.id];
            saveData(appData);
            updateThreeThingsUI();
        }

        function copyPrompt() {
            const text = document.getElementById('promptCode').textContent.trim();
            navigator.clipboard.writeText(text).then(() => {
                $copyPromptBtn.textContent = '✓ 已复制';
                $copyPromptBtn.classList.add('copied');
                showToast('📋 提示词已复制');
                setTimeout(() => { $copyPromptBtn.textContent = '📋 复制';
                    $copyPromptBtn.classList.remove('copied'); }, 2000);
            }).catch(() => showToast('⚠️ 复制失败，请手动选择复制'));
        }

        function clearErrors() {
            appData.errors = { err1: '', err2: '', err3: '' };
            saveData(appData);
            document.querySelectorAll('#errorTop3 .editable-inline').forEach(el => {
                el.textContent = el.dataset.key === 'err1' ? '点击填写最高频错误' : el.dataset.key === 'err2' ?
                    '点击填写第二高频错误' : '点击填写第三高频错误';
            });
            showToast('🗑️ 本周错误记录已清空');
        }

        function clearAllData() {
            if (confirm('确定清除所有数据吗？包括 streak、任务记录、错误记录和云端数据。此操作不可撤销。')) {
                localStorage.removeItem(STORAGE_KEY);
                appData = getDefaultData();
                saveData(appData);
                renderChecklist();
                updateAllUI();
                setStatus('idle', '未开始');
                document.querySelectorAll('.editable-inline').forEach(el => {
                    el.textContent = el.dataset.key === 'commitTime' ? '___:___' : el.dataset.key ===
                        'commitPlace' ? '____________' : el.dataset.key === 'reward30' ?
                        '________________________' : el.dataset.key === 'reward60' ?
                        '________________________' : el.dataset.key === 'err1' ? '点击填写最高频错误' : el
                        .dataset.key === 'err2' ? '点击填写第二高频错误' : '点击填写第三高频错误';
                });
                showToast('⚠️ 所有数据已清除');
            }
        }

        function resetStreak() {
            if (confirm('确定重置连续打卡记录吗？将清除所有完成日期。')) {
                appData.completedDates = [];
                appData.taskChecks = {};
                saveData(appData);
                renderChecklist();
                updateAllUI();
                setStatus('idle', '未开始');
                showToast('🔄 Streak 已重置');
            }
        }

        function exportData() {
            const blob = new Blob([JSON.stringify(appData, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `eng-b1-b2-backup-${todayStr}.json`;
            a.click();
            URL.revokeObjectURL(url);
            showToast('📥 数据已导出为 JSON 文件');
        }

        function importData() {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = '.json';
            input.onchange = (e) => {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = (ev) => {
                    try {
                        const imported = JSON.parse(ev.target.result);
                        const defaults = getDefaultData();
                        for (const key in defaults) { if (!(key in imported)) imported[key] = defaults[
                            key]; }
                        appData = imported;
                        saveData(appData);
                        renderChecklist();
                        updateAllUI();
                        showToast('📤 数据已导入！');
                    } catch (err) {
                        showToast('❌ 文件格式错误，无法导入');
                    }
                };
                reader.readAsText(file);
            };
            input.click();
        }

        function showToast(msg) {
            $toast.textContent = msg;
            $toast.classList.add('show');
            clearTimeout($toast._timeout);
            $toast._timeout = setTimeout(() => $toast.classList.remove('show'), 2200);
        }

        function toggleCollapsible(el) { el.classList.toggle('open'); }

        // ============ EDITABLE LISTENERS ============
        function setupEditableListeners() {
            document.querySelectorAll('.editable-inline[data-key]').forEach(el => {
                el.addEventListener('blur', () => {
                    const key = el.dataset.key;
                    const text = el.textContent.trim();
                    if (['err1', 'err2', 'err3'].includes(key)) appData.errors[key] = text;
                    else appData[key] = text;
                    saveData(appData);
                    if (key === 'reward30' || key === 'reward60') updateRewards();
                });
                el.addEventListener('keydown', (e) => { if (e.key === 'Enter') { e.preventDefault();
                        el.blur(); } });
            });
        }

        function setupScrollListener() {
            window.addEventListener('scroll', () => {
                $progressWrap.classList.toggle('scrolled', window.scrollY > 50);
            });
        }

        // ============ INIT ============
        async function init() {
            // 1. 立即加载本地数据并渲染（快速首屏）
            appData = loadLocalData();
            renderChecklist();
            updateAllUI();
            updateHeroDate();
            setupEditableListeners();
            setupScrollListener();
            updateEditableFields();
            updateErrorFields();
            if (isTodayCompleted()) {
                setStatus('done', '已完成');
                const tasks = getTasksForDay();
                if (!appData.taskChecks[todayStr]) appData.taskChecks[todayStr] = {};
                tasks.forEach(t => { appData.taskChecks[todayStr][t.id] = true; });
                saveLocalData(appData);
                renderChecklist();
                updateCompletionSummary();
            }

            // 2. 后台初始化 Firebase 认证
            await initAuth();

            // 3. 从云端同步数据
            if (currentUser) {
                const cloudData = await loadFromCloud();
                if (cloudData) {
                    const merged = mergeData(appData, cloudData);
                    if (JSON.stringify(merged) !== JSON.stringify(appData)) {
                        appData = merged;
                        saveLocalData(appData);
                        renderChecklist();
                        updateAllUI();
                        console.log('☁️ 云端数据已合并到本地');
                    }
                } else {
                    // 云端无数据，推送本地数据
                    await saveToCloud(appData);
                }
                updateSyncTimeDisplay();
            } else {
                setSyncState('offline');
                console.log('📁 离线模式，仅使用本地存储');
            }

            console.log('📊 英语 B1→B2 训练面板已就绪 | 今日: ' + getDayTypeInfo().type + ' | Streak: ' + calcStreak(appData
                .completedDates) + ' 天 | 同步: ' + syncState);
        }

        // ============ GLOBAL EXPOSURES ============
        window.scrollToTasks = scrollToTasks;
        window.scrollToMinimal = scrollToMinimal;
        window.markAllDone = markAllDone;
        window.resetToday = resetToday;
        window.toggleThing = toggleThing;
        window.copyPrompt = copyPrompt;
        window.clearErrors = clearErrors;
        window.clearAllData = clearAllData;
        window.resetStreak = resetStreak;
        window.toggleCollapsible = toggleCollapsible;
        window.manualSync = manualSync;
        window.exportData = exportData;
        window.importData = importData;

        // ============ START ============
        init();
    </script>
</body>
</html>